# Production Domains & URLs
DOMAIN_NAME=yourdomain.com
PUBLIC_API_URL=https://yourdomain.com/api

# Docker Image Tags (Built via Bazel or CI/CD)
WEB_APP_IMAGE=jumpa-web-app:latest
GATEWAY_API_IMAGE=jumpa-gateway-api:latest
SPATIAL_COMPUTE_IMAGE=jumpa-spatial-compute:latest

# Security & Credentials (CHANGE THESE IN PRODUCTION!)
DB_USER=jumpa_prod_user
DB_PASSWORD=make_a_very_strong_password_here
DB_NAME=jumpa_prod

MINIO_ROOT_USER=minio_admin_prod
MINIO_ROOT_PASSWORD=make_another_strong_password_here

# Port Configuration for Public Services
HTTP_PORT=80
HTTPS_PORT=443

# ScyllaDB Production Settings (Resource limitations)
SCYLLA_COMMAND=--smp 2 --memory 2G

# Grafana Admin Configuration (if exposed)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=make_a_grafana_admin_password_here
